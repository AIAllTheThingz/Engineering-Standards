{
  "schemaVersion": "1.0.0",
  "patterns": [
    {
      "id": "embedded-credential-assignment",
      "description": "Possible embedded credential assignment.",
      "severity": "error",
      "regex": "(?i)(password|passwd|pwd|secret|api[_-]?key|token)\\s*[:=]\\s*\\S{8,}"
    },
    {
      "id": "private-key-block",
      "description": "Private key marker.",
      "severity": "error",
      "regex": "-----BEGIN [A-Z ]*PRIVATE KEY-----"
    },
    {
      "id": "disabled-tls-validation",
      "description": "TLS validation appears disabled.",
      "severity": "error",
      "regex": "(?i)(TrustServerCertificate\\s*=\\s*true|ServerCertificateValidationCallback)"
    },
    {
      "id": "dangerous-powershell-expression",
      "description": "Dynamic PowerShell execution.",
      "severity": "warning",
      "regex": "(?i)Invoke-Expression|\\biex\\b"
    },
    {
      "id": "broad-destructive-command",
      "description": "Broad destructive command.",
      "severity": "error",
      "regex": "(?i)(Remove-Item|rm|del)\\s+.*(-Recurse|/s).*(\\*|[A-Z]:\\\\)"
    },
    {
      "id": "empty-catch",
      "description": "Empty catch block.",
      "severity": "warning",
      "regex": "(?s)catch\\s*\\{\\s*\\}"
    },
    {
      "id": "hardcoded-production-endpoint",
      "description": "Hardcoded production endpoint.",
      "severity": "warning",
      "regex": "(?i)https?://[^\\s\\\"']*(prod|production)[^\\s\\\"']*"
    },
    {
      "id": "broad-workflow-permissions",
      "description": "Workflow grants broad write permissions.",
      "severity": "error",
      "regex": "(?m)^\\s*permissions:\\s*write-all\\s*$"
    },
    {
      "id": "pull-request-target",
      "description": "pull_request_target requires review.",
      "severity": "warning",
      "regex": "pull_request_target"
    },
    {
      "id": "download-execute",
      "description": "Downloaded content piped to execution.",
      "severity": "error",
      "regex": "(?i)(curl|wget|Invoke-WebRequest|iwr).*(\\||;).*?(sh|bash|pwsh|powershell|iex)"
    }
  ]
}
