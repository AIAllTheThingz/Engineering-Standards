{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aiallthethingz.example/engineering-standards/standards-consistency.schema.json",
  "title": "Standards Consistency Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "repository",
    "repositoryVersion",
    "defaultBranch",
    "riskClassification",
    "generatedFromCommit",
    "generatedAtUtc",
    "canonicalStatusValues",
    "canonicalRiskValues",
    "documents",
    "workflowReview",
    "githubEvidence",
    "branchProtection",
    "releaseReadiness"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^1\\.0\\.0$" },
    "repository": { "type": "string", "const": "AIAllTheThingz/Engineering-Standards" },
    "repositoryVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "defaultBranch": { "type": "string", "const": "master" },
    "riskClassification": { "type": "string", "enum": [ "Low", "Moderate", "High", "Critical" ] },
    "generatedFromCommit": { "type": "string", "pattern": "^[A-Fa-f0-9]{40}$" },
    "generatedAtUtc": { "type": "string", "format": "date-time" },
    "canonicalStatusValues": {
      "type": "array",
      "items": { "type": "string", "enum": [ "Passed", "Failed", "Blocked", "NotRun", "NotApplicable" ] },
      "minItems": 5,
      "uniqueItems": true
    },
    "canonicalRiskValues": {
      "type": "array",
      "items": { "type": "string", "enum": [ "Low", "Moderate", "High", "Critical" ] },
      "minItems": 4,
      "uniqueItems": true
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "kind",
          "declaredVersion",
          "status",
          "lastReviewed",
          "ownerRole",
          "parentDocuments",
          "childOrHandoffStandards",
          "notRunDefined",
          "blockedDefined",
          "fabricatedEvidenceProhibited",
          "exceptionProcessReferenced",
          "completionEvidenceReferenced",
          "validationCommandsPresent",
          "validatorMinimumVersion",
          "positiveValidatorCoverage",
          "negativeWeakeningCoverage",
          "pesterMutationCoverage",
          "identifiedDiscrepancies",
          "resolution"
        ],
        "properties": {
          "path": { "type": "string", "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+" },
          "kind": { "type": "string", "enum": [ "governance", "root", "base-standard", "technology-standard", "documentation" ] },
          "declaredVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "status": { "type": "string", "enum": [ "Active", "Draft", "Deprecated" ] },
          "lastReviewed": { "type": "string", "format": "date" },
          "ownerRole": { "type": "string", "minLength": 3 },
          "parentDocuments": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "childOrHandoffStandards": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
          "notRunDefined": { "type": "boolean" },
          "blockedDefined": { "type": "boolean" },
          "fabricatedEvidenceProhibited": { "type": "boolean" },
          "exceptionProcessReferenced": { "type": "boolean" },
          "completionEvidenceReferenced": { "type": "boolean" },
          "validationCommandsPresent": { "type": "boolean" },
          "validatorMinimumVersion": { "type": [ "string", "null" ], "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "positiveValidatorCoverage": { "type": "string", "enum": [ "Present", "NotApplicable", "Gap" ] },
          "negativeWeakeningCoverage": { "type": "string", "enum": [ "Present", "NotApplicable", "Gap" ] },
          "pesterMutationCoverage": { "type": "string", "enum": [ "Present", "NotApplicable", "Gap" ] },
          "identifiedDiscrepancies": { "type": "array", "items": { "type": "string" } },
          "resolution": { "type": "string", "minLength": 3 }
        }
      }
    },
    "workflowReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "status", "summary", "workflowsInspected" ],
      "properties": {
        "status": { "type": "string", "enum": [ "Passed", "Failed", "Blocked", "NotRun", "NotApplicable" ] },
        "summary": { "type": "string", "minLength": 10 },
        "workflowsInspected": { "type": "array", "items": { "type": "string" }, "minItems": 1, "uniqueItems": true }
      }
    },
    "githubEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "status", "reason" ],
      "properties": {
        "status": { "type": "string", "enum": [ "Passed", "Failed", "Blocked", "NotRun", "NotApplicable" ] },
        "reason": { "type": "string", "minLength": 10 }
      }
    },
    "branchProtection": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "status", "reason" ],
      "properties": {
        "status": { "type": "string", "enum": [ "Passed", "Failed", "Blocked", "NotRun", "NotApplicable" ] },
        "reason": { "type": "string", "minLength": 10 }
      }
    },
    "releaseReadiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "status", "proposedVersion", "proposedTag", "targetCommitSha", "releaseCreated", "reason" ],
      "properties": {
        "status": { "type": "string", "enum": [ "Passed", "Failed", "Blocked", "NotRun", "NotApplicable" ] },
        "proposedVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "proposedTag": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "targetCommitSha": { "type": "string", "pattern": "^[A-Fa-f0-9]{40}$" },
        "releaseCreated": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 10 }
      }
    }
  }
}
