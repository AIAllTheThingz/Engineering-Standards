{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aiallthethingz.example/engineering-standards/test-evidence.schema.json",
  "title": "Test Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "category",
    "status",
    "command",
    "workingDirectory",
    "startedAtUtc",
    "completedAtUtc",
    "durationSeconds",
    "runtime",
    "toolVersion",
    "exitCode",
    "summary",
    "warnings",
    "failureReason"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": [
        "1.0.0",
        "1.1.0"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._:/()#-]*$"
    },
    "category": {
      "type": "string",
      "enum": [
        "unit",
        "integration",
        "security",
        "build",
        "lint",
        "schema",
        "workflow",
        "documentation",
        "manual",
        "other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "Passed",
        "Failed",
        "NotRun",
        "NotApplicable",
        "Blocked"
      ]
    },
    "requiredValidation": {
      "type": "boolean",
      "default": true
    },
    "evidenceSource": {
      "type": "string",
      "enum": [
        "Automated",
        "Manual",
        "Static",
        "GitHubArtifact"
      ]
    },
    "command": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "workingDirectory": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+"
    },
    "startedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "completedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "durationSeconds": {
      "type": "number",
      "minimum": 0
    },
    "runtime": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "toolVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "environment": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 2,
      "maxLength": 120
    },
    "exitCode": {
      "type": [
        "integer",
        "null"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failureReason": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 10
    },
    "blockedReason": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 10
    },
    "notApplicableRationale": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 10
    },
    "manualProcedure": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 10,
      "maxLength": 2000
    },
    "executionMode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dryRun": { "type": "boolean" },
        "whatIf": { "type": "boolean" },
        "planOnly": { "type": "boolean" },
        "applied": { "type": "boolean" }
      }
    },
    "details": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "Passed"
          }
        }
      },
      "then": {
        "properties": {
          "exitCode": {
            "const": 0
          },
          "failureReason": {
            "type": "null"
          },
          "blockedReason": {
            "type": "null"
          },
          "notApplicableRationale": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "Failed"
          }
        }
      },
      "then": {
        "properties": {
          "failureReason": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "Blocked"
          }
        }
      },
      "then": {
        "properties": {
          "blockedReason": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "NotRun"
          }
        }
      },
      "then": {
        "properties": {
          "failureReason": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "NotApplicable"
          }
        }
      },
      "then": {
        "properties": {
          "notApplicableRationale": {
            "type": "string",
            "minLength": 10
          },
          "exitCode": {
            "type": "null"
          }
        }
      }
    }
  ]
}
