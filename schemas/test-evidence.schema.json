{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aiallthethingz.example/engineering-standards/test-evidence.schema.json",
  "title": "Test Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "category",
    "status",
    "command",
    "workingDirectory",
    "startedAtUtc",
    "completedAtUtc",
    "durationSeconds",
    "runtime",
    "toolVersion",
    "exitCode",
    "summary",
    "warnings",
    "failureReason"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._:/()#-]*$"
    },
    "category": {
      "type": "string",
      "enum": [
        "unit",
        "integration",
        "security",
        "build",
        "lint",
        "schema",
        "workflow",
        "documentation",
        "manual",
        "other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "Passed",
        "Failed",
        "NotRun",
        "NotApplicable",
        "Blocked"
      ]
    },
    "command": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "workingDirectory": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+"
    },
    "startedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "completedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "durationSeconds": {
      "type": "number",
      "minimum": 0
    },
    "runtime": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "toolVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "exitCode": {
      "type": [
        "integer",
        "null"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failureReason": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 10
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "Passed"
          }
        }
      },
      "then": {
        "properties": {
          "exitCode": {
            "const": 0
          },
          "failureReason": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "Failed",
              "NotRun",
              "Blocked"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "failureReason": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "NotRun"
          }
        }
      },
      "then": {
        "properties": {
          "exitCode": {
            "type": [
              "integer",
              "null"
            ]
          }
        }
      }
    }
  ]
}
