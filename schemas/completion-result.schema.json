{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aiallthethingz.example/engineering-standards/completion-result.schema.json",
  "title": "Completion Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "repository",
    "commitSha",
    "branch",
    "pullRequest",
    "governanceVersion",
    "riskClassification",
    "status",
    "startedAtUtc",
    "completedAtUtc",
    "summary",
    "changedFiles",
    "commandsExecuted",
    "commandsNotExecuted",
    "tests",
    "artifacts",
    "warnings",
    "knownLimitations",
    "remainingRisks",
    "exceptions",
    "approvals"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "repository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "commitSha": {
      "type": "string",
      "pattern": "^([A-Fa-f0-9]{40}|unknown)$"
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "pullRequest": {
      "type": [
        "string",
        "null"
      ]
    },
    "governanceVersion": {
      "type": "string",
      "minLength": 1
    },
    "riskClassification": {
      "type": "string",
      "enum": [
        "Low",
        "Moderate",
        "High",
        "Critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "Passed",
        "Failed",
        "NotRun",
        "NotApplicable",
        "Blocked"
      ]
    },
    "startedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "completedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string",
      "minLength": 20
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "commandsExecuted": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "commandsNotExecuted": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "$ref": "test-evidence.schema.json"
      },
      "minItems": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "artifact-record.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "knownLimitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "remainingRisks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^GOV-[A-Z0-9-]+$"
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "role",
          "approvedAtUtc"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "approvedAtUtc": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
