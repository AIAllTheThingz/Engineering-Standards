{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aiallthethingz.example/engineering-standards/completion-result.schema.json",
  "title": "Completion Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "executionContext",
    "repository",
    "commitSha",
    "validatedCommitSha",
    "evidenceCommitSha",
    "branch",
    "pullRequest",
    "governanceVersion",
    "riskClassification",
    "status",
    "startedAtUtc",
    "completedAtUtc",
    "summary",
    "changedFiles",
    "commandsExecuted",
    "commandsNotExecuted",
    "tests",
    "artifacts",
    "warnings",
    "knownLimitations",
    "remainingRisks",
    "exceptions",
    "approvals"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": [
        "1.0.0",
        "1.1.0"
      ]
    },
    "executionContext": {
      "type": "string",
      "enum": [
        "Local",
        "GitHubActions",
        "PullRequest",
        "Scheduled",
        "Release"
      ]
    },
    "githubRunId": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]+$"
    },
    "githubRunAttempt": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]+$"
    },
    "githubWorkflow": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "githubJob": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 160
    },
    "artifactName": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 3
    },
    "repository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "commitSha": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "validatedCommitSha": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "evidenceCommitSha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "branch": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^(?!/)(?!.*\\.\\.)(?!.*//)(?!.*@$).+"
    },
    "pullRequest": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^(https://github\\.com/[^/]+/[^/]+/pull/[0-9]+|#[0-9]+)$"
    },
    "governanceVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
    },
    "riskClassification": {
      "type": "string",
      "enum": [
        "Low",
        "Moderate",
        "High",
        "Critical"
      ]
    },
    "changeCategory": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "documentation",
        "schema",
        "workflow",
        "release",
        "application",
        "database",
        "infrastructure",
        "integration",
        "mixed",
        null
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "Passed",
        "Failed",
        "NotRun",
        "NotApplicable",
        "Blocked"
      ]
    },
    "startedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "completedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "durationSeconds": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "summary": {
      "type": "string",
      "minLength": 40,
      "maxLength": 4000
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "changedFileCategories": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "documentation",
        "configuration",
        "tests",
        "generatedEvidence",
        "generatedBuildOutput"
      ],
      "properties": {
        "source": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "documentation": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "configuration": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "tests": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "generatedEvidence": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "generatedBuildOutput": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 2, "maxLength": 120 },
        "type": { "type": "string", "minLength": 2, "maxLength": 120 },
        "production": { "type": "boolean" },
        "tenant": { "type": ["string", "null"], "minLength": 1, "maxLength": 160 },
        "account": { "type": ["string", "null"], "minLength": 1, "maxLength": 160 },
        "subscription": { "type": ["string", "null"], "minLength": 1, "maxLength": 160 },
        "project": { "type": ["string", "null"], "minLength": 1, "maxLength": 160 },
        "region": { "type": ["string", "null"], "minLength": 1, "maxLength": 120 },
        "zone": { "type": ["string", "null"], "minLength": 1, "maxLength": 120 },
        "cluster": { "type": ["string", "null"], "minLength": 1, "maxLength": 120 },
        "namespace": { "type": ["string", "null"], "minLength": 1, "maxLength": 120 }
      }
    },
    "productionChange": {
      "type": "boolean"
    },
    "approvalRequired": {
      "type": "boolean"
    },
    "executionMode": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dryRun": { "type": "boolean" },
        "whatIf": { "type": "boolean" },
        "planOnly": { "type": "boolean" },
        "applied": { "type": "boolean" }
      }
    },
    "dataClassification": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "Public",
        "Internal",
        "Confidential",
        "Regulated",
        null
      ]
    },
    "identityUsed": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 2,
      "maxLength": 200
    },
    "credentialMode": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 2,
      "maxLength": 120
    },
    "notRunReason": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 10
    },
    "blockedReason": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 10
    },
    "notApplicableRationale": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 10
    },
    "commandsExecuted": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 2000
      },
      "minItems": 1
    },
    "commandsNotExecuted": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10,
        "maxLength": 2000
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "$ref": "test-evidence.schema.json"
      },
      "minItems": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "artifact-record.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      },
      "uniqueItems": true
    },
    "knownLimitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      },
      "uniqueItems": true
    },
    "remainingRisks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      },
      "uniqueItems": true
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^GOV-[A-Z0-9-]+$"
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "role",
          "approvedAtUtc"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 2 },
          "role": { "type": "string", "minLength": 2 },
          "approvedAtUtc": { "type": "string", "format": "date-time" },
          "approvalType": { "type": ["string", "null"], "minLength": 2, "maxLength": 120 },
          "scope": { "type": ["string", "null"], "minLength": 2, "maxLength": 200 },
          "environment": { "type": ["string", "null"], "minLength": 2, "maxLength": 120 },
          "ticketReference": { "type": ["string", "null"], "minLength": 2, "maxLength": 120 },
          "expiresAtUtc": { "type": ["string", "null"], "format": "date-time" },
          "approvedCommitSha": { "type": ["string", "null"], "pattern": "^[A-Fa-f0-9]{40}$" },
          "approvedPlanHash": { "type": ["string", "null"], "pattern": "^[A-Fa-f0-9]{64}$" },
          "approvedArtifactHash": { "type": ["string", "null"], "pattern": "^[A-Fa-f0-9]{64}$" },
          "separationOfDuties": { "type": ["boolean", "null"] }
        }
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maintenanceWindow": { "type": ["string", "null"], "minLength": 2, "maxLength": 200 },
        "rollbackPlan": { "type": ["string", "null"], "minLength": 10, "maxLength": 4000 },
        "rollbackTestedStatus": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "Passed",
            "Failed",
            "Blocked",
            "NotRun",
            "NotApplicable",
            null
          ]
        },
        "rollForwardPlan": { "type": ["string", "null"], "minLength": 10, "maxLength": 4000 },
        "backupRequired": { "type": ["boolean", "null"] },
        "backupVerification": { "type": ["string", "null"], "minLength": 10, "maxLength": 2000 },
        "restoreVerification": { "type": ["string", "null"], "minLength": 10, "maxLength": 2000 },
        "destructiveOperations": { "type": ["boolean", "null"] }
      }
    },
    "technologyEvidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "powershell": { "type": "object" },
        "dotnet": { "type": "object" },
        "database": { "type": "object" },
        "workerService": { "type": "object" },
        "integration": { "type": "object" },
        "infrastructure": { "type": "object" },
        "webFrontend": { "type": "object" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "NotRun"
          }
        }
      },
      "then": {
        "properties": {
          "commandsNotExecuted": {
            "minItems": 1
          },
          "notRunReason": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "Blocked"
          }
        }
      },
      "then": {
        "properties": {
          "blockedReason": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "NotApplicable"
          }
        }
      },
      "then": {
        "properties": {
          "notApplicableRationale": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "approvalRequired": {
            "const": true
          },
          "status": {
            "const": "Passed"
          }
        }
      },
      "then": {
        "properties": {
          "approvals": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
