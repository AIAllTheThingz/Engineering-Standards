{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aiallthethingz.example/engineering-standards/completion-result.schema.json",
  "title": "Completion Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "executionContext",
    "repository",
    "commitSha",
    "validatedCommitSha",
    "evidenceCommitSha",
    "branch",
    "pullRequest",
    "governanceVersion",
    "riskClassification",
    "status",
    "startedAtUtc",
    "completedAtUtc",
    "summary",
    "changedFiles",
    "commandsExecuted",
    "commandsNotExecuted",
    "tests",
    "artifacts",
    "warnings",
    "knownLimitations",
    "remainingRisks",
    "exceptions",
    "approvals"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "executionContext": {
      "type": "string",
      "enum": [
        "Local",
        "GitHubActions",
        "PullRequest",
        "Scheduled",
        "Release"
      ]
    },
    "githubRunId": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]+$"
    },
    "githubRunAttempt": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]+$"
    },
    "githubWorkflow": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "artifactName": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 3
    },
    "repository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "commitSha": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "validatedCommitSha": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "evidenceCommitSha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "branch": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^(?!/)(?!.*\\.\\.)(?!.*//)(?!.*@$).+"
    },
    "pullRequest": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^(https://github\\.com/[^/]+/[^/]+/pull/[0-9]+|#[0-9]+)$"
    },
    "governanceVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
    },
    "riskClassification": {
      "type": "string",
      "enum": [
        "Low",
        "Moderate",
        "High",
        "Critical"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "Passed",
        "Failed",
        "NotRun",
        "NotApplicable",
        "Blocked"
      ]
    },
    "startedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "completedAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string",
      "minLength": 40,
      "maxLength": 4000
    },
    "changedFiles": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "changedFileCategories": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "documentation",
        "configuration",
        "tests",
        "generatedEvidence",
        "generatedBuildOutput"
      ],
      "properties": {
        "source": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "documentation": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "configuration": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "tests": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "generatedEvidence": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "generatedBuildOutput": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "commandsExecuted": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 2000
      },
      "minItems": 1
    },
    "commandsNotExecuted": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10,
        "maxLength": 2000
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "$ref": "test-evidence.schema.json"
      },
      "minItems": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "artifact-record.schema.json"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      },
      "uniqueItems": true
    },
    "knownLimitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      },
      "uniqueItems": true
    },
    "remainingRisks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 10
      },
      "uniqueItems": true
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^GOV-[A-Z0-9-]+$"
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "role",
          "approvedAtUtc"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 2
          },
          "role": {
            "type": "string",
            "minLength": 2
          },
          "approvedAtUtc": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "NotRun"
          }
        }
      },
      "then": {
        "properties": {
          "commandsNotExecuted": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "Passed"
          }
        }
      },
      "then": {
        "properties": {
          "remainingRisks": {
            "maxItems": 0
          }
        }
      }
    }
  ]
}
