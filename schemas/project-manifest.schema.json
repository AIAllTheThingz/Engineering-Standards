{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:aiallthethingz:engineering-standards:schema:project-manifest",
  "title": "Project Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectName",
    "repository",
    "description",
    "projectType",
    "technologies",
    "governanceVersion",
    "riskClassification",
    "dataClassification",
    "owners",
    "environments",
    "applicableStandards",
    "requiredWorkflows",
    "externalIntegrations",
    "secretsProvider",
    "productionApprovalRequired",
    "evidence",
    "exceptions"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": [
        "1.0.0",
        "1.1.0",
        "1.2.0"
      ]
    },
    "projectName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._-]*$"
    },
    "repository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "description": {
      "type": "string",
      "minLength": 40,
      "maxLength": 1000
    },
    "projectType": {
      "type": "string",
      "enum": [
        "powershell",
        "dotnet",
        "web",
        "database",
        "worker-service",
        "integration",
        "infrastructure",
        "governance",
        "mixed"
      ]
    },
    "technologies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "governanceVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
    },
    "governanceCommitSha": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "workflowInterfaceVersion": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
    },
    "repositoryOwnerType": {
      "type": "string",
      "enum": [
        "User",
        "Organization"
      ]
    },
    "supportedEvidenceSchemaVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^1\\.[01]\\.0$"
      },
      "uniqueItems": true
    },
    "riskClassification": {
      "type": "string",
      "enum": [
        "Low",
        "Moderate",
        "High",
        "Critical"
      ]
    },
    "dataClassification": {
      "type": "string",
      "enum": [
        "Public",
        "Internal",
        "Confidential",
        "Regulated"
      ]
    },
    "owners": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/legacyOwner" },
          { "$ref": "#/$defs/structuredOwner" }
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "environments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "type",
          "production"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 2, "maxLength": 80 },
          "type": {
            "type": "string",
            "enum": [
              "development",
              "test",
              "staging",
              "production"
            ]
          },
          "production": { "type": "boolean" },
          "region": { "type": ["string", "null"], "minLength": 1, "maxLength": 80 },
          "zone": { "type": ["string", "null"], "minLength": 1, "maxLength": 80 },
          "cluster": { "type": ["string", "null"], "minLength": 1, "maxLength": 80 },
          "namespace": { "type": ["string", "null"], "minLength": 1, "maxLength": 80 }
        }
      }
    },
    "applicableStandards": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^agents/AGENTS_[A-Za-z]+\\.md$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "standardsConsumption": {
      "$ref": "#/$defs/standardsConsumption"
    },
    "requiredWorkflows": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "externalIntegrations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "purpose",
          "dataClassification"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 2 },
          "purpose": { "type": "string", "minLength": 20 },
          "dataClassification": {
            "type": "string",
            "enum": [
              "Public",
              "Internal",
              "Confidential",
              "Regulated"
            ]
          },
          "contractVersion": { "type": ["string", "null"], "minLength": 1, "maxLength": 80 },
          "authenticationMethod": { "type": ["string", "null"], "minLength": 1, "maxLength": 120 }
        }
      }
    },
    "secretsProvider": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "productionApprovalRequired": {
      "type": "boolean"
    },
    "evidence": {
      "oneOf": [
        { "$ref": "#/$defs/legacyEvidence" },
        { "$ref": "#/$defs/structuredEvidence" }
      ]
    },
    "exceptions": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string", "pattern": "^GOV-[A-Z0-9-]+$" },
          { "$ref": "#/$defs/exceptionRecord" }
        ]
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "relativeJsonPath": {
      "type": "string",
      "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/)(?!\\\\).+\\.json$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/)(?!\\\\).+"
    },
    "legacyOwner": {
      "type": "string",
      "minLength": 2,
      "pattern": "^(@[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?(?:/[A-Za-z0-9](?:[A-Za-z0-9_.-]*[A-Za-z0-9])?)?|[A-Za-z0-9_.+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,})$",
      "not": {
        "pattern": "^(?:@(?:(?:[Pp][Ll][Aa][Cc][Ee][Hh][Oo][Ll][Dd][Ee][Rr]|[Cc][Hh][Aa][Nn][Gg][Ee][Mm][Ee]|[Rr][Ee][Pp][Ll][Aa][Cc][Ee]-[Mm][Ee]|[Tt][Oo][Dd][Oo])(?:/|$)|[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?/(?:[Pp][Ll][Aa][Cc][Ee][Hh][Oo][Ll][Dd][Ee][Rr]|[Cc][Hh][Aa][Nn][Gg][Ee][Mm][Ee]|[Rr][Ee][Pp][Ll][Aa][Cc][Ee]-[Mm][Ee]|[Tt][Oo][Dd][Oo])$)|(?:[Pp][Ll][Aa][Cc][Ee][Hh][Oo][Ll][Dd][Ee][Rr]|[Cc][Hh][Aa][Nn][Gg][Ee][Mm][Ee]|[Rr][Ee][Pp][Ll][Aa][Cc][Ee]-[Mm][Ee]|[Tt][Oo][Dd][Oo])@)"
      }
    },
    "structuredOwner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "identifier", "responsibility", "escalation"],
      "properties": {
        "type": { "enum": ["github-user", "github-team", "email-contact"] },
        "identifier": {
          "type": "string",
          "minLength": 2,
          "maxLength": 254,
          "not": { "pattern": "(?i:placeholder|changeme|replace-me|todo)" }
        },
        "responsibility": { "type": "string", "minLength": 20, "maxLength": 500 },
        "escalation": { "type": "string", "minLength": 2, "maxLength": 254 },
        "displayName": { "type": "string", "minLength": 2, "maxLength": 120 }
      },
      "allOf": [
        { "if": { "properties": { "type": { "const": "github-user" } } }, "then": { "properties": { "identifier": { "pattern": "^@[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$" } } } },
        { "if": { "properties": { "type": { "const": "github-team" } } }, "then": { "properties": { "identifier": { "pattern": "^@[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?/[A-Za-z0-9](?:[A-Za-z0-9_.-]*[A-Za-z0-9])?$" } } } },
        { "if": { "properties": { "type": { "const": "email-contact" } } }, "then": { "properties": { "identifier": { "pattern": "^[A-Za-z0-9_.+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$" } } } }
      ]
    },
    "standardsConsumption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["central-reference", "vendored", "local"] },
        "sourceRepository": { "type": "string", "pattern": "^[^/]+/[^/]+$" },
        "sourceCommitSha": { "type": "string", "pattern": "^[A-Fa-f0-9]{40}$" },
        "localPath": { "$ref": "#/$defs/relativePath" }
      },
      "allOf": [
        { "if": { "properties": { "mode": { "const": "central-reference" } } }, "then": { "required": ["sourceRepository", "sourceCommitSha"], "not": { "required": ["localPath"] } } },
        { "if": { "properties": { "mode": { "const": "vendored" } } }, "then": { "required": ["sourceRepository", "sourceCommitSha", "localPath"] } },
        { "if": { "properties": { "mode": { "const": "local" } } }, "then": { "required": ["localPath"], "not": { "anyOf": [{ "required": ["sourceRepository"] }, { "required": ["sourceCommitSha"] }] } } }
      ]
    },
    "legacyEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["completionEvidencePath", "testEvidencePath"],
      "properties": {
        "completionEvidencePath": { "$ref": "#/$defs/relativeJsonPath" },
        "testEvidencePath": { "$ref": "#/$defs/relativeJsonPath" },
        "artifactManifestPath": { "oneOf": [{ "$ref": "#/$defs/relativeJsonPath" }, { "type": "null" }] }
      }
    },
    "structuredEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["local", "hosted"],
      "properties": {
        "local": {
          "type": "object", "additionalProperties": false, "required": ["completion", "tests"],
          "properties": { "completion": { "$ref": "#/$defs/relativeJsonPath" }, "tests": { "$ref": "#/$defs/relativeJsonPath" } }
        },
        "hosted": {
          "type": "object", "additionalProperties": false, "required": ["workspace", "completion", "tests", "artifactNamePattern"],
          "properties": {
            "workspace": { "$ref": "#/$defs/relativePath" },
            "completion": { "$ref": "#/$defs/relativeJsonPath" },
            "tests": { "$ref": "#/$defs/relativeJsonPath" },
            "artifactNamePattern": { "type": "string", "pattern": "^governance-evidence-\\$\\{run_id\\}$" }
          }
        }
      }
    },
    "exceptionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identifier", "status", "scope", "owner", "approver", "approvalDate", "expiration", "affectedControl", "compensatingControls", "remediationPlan", "evidenceReference"],
      "properties": {
        "identifier": { "type": "string", "pattern": "^GOV-[A-Z0-9-]+$" },
        "status": { "enum": ["Approved", "Rejected", "Revoked", "Expired"] },
        "scope": { "type": "string", "minLength": 10, "maxLength": 500 },
        "owner": { "type": "string", "minLength": 2, "maxLength": 254 },
        "approver": { "type": "string", "minLength": 2, "maxLength": 254 },
        "approvalDate": { "type": "string", "format": "date" },
        "expiration": { "type": "string", "format": "date" },
        "affectedControl": { "type": "string", "minLength": 3, "maxLength": 160 },
        "compensatingControls": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 10 }, "uniqueItems": true },
        "remediationPlan": { "type": "string", "minLength": 20, "maxLength": 1000 },
        "evidenceReference": { "$ref": "#/$defs/relativePath" }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "riskClassification": {
            "enum": [
              "High",
              "Critical"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "productionApprovalRequired": {
            "const": true
          }
        }
      }
    },
    {
      "if": { "properties": { "schemaVersion": { "const": "1.2.0" } } },
      "then": {
        "required": ["governanceCommitSha", "workflowInterfaceVersion", "repositoryOwnerType", "standardsConsumption"],
        "properties": {
          "workflowInterfaceVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$" },
          "owners": { "items": { "$ref": "#/$defs/structuredOwner" } },
          "evidence": { "$ref": "#/$defs/structuredEvidence" },
          "exceptions": { "items": { "$ref": "#/$defs/exceptionRecord" } }
        }
      },
      "else": {
        "properties": {
          "owners": { "items": { "$ref": "#/$defs/legacyOwner" } },
          "evidence": { "$ref": "#/$defs/legacyEvidence" },
          "exceptions": { "items": { "type": "string", "pattern": "^GOV-[A-Z0-9-]+$" } }
        }
      }
    }
  ]
}
