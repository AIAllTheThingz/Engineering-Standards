{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aiallthethingz.example/engineering-standards/project-manifest.schema.json",
  "title": "Project Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "projectName",
    "repository",
    "description",
    "projectType",
    "technologies",
    "governanceVersion",
    "riskClassification",
    "dataClassification",
    "owners",
    "environments",
    "applicableStandards",
    "requiredWorkflows",
    "externalIntegrations",
    "secretsProvider",
    "productionApprovalRequired",
    "evidence",
    "exceptions"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": [
        "1.0.0",
        "1.1.0"
      ]
    },
    "projectName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._-]*$"
    },
    "repository": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$"
    },
    "description": {
      "type": "string",
      "minLength": 40,
      "maxLength": 1000
    },
    "projectType": {
      "type": "string",
      "enum": [
        "powershell",
        "dotnet",
        "web",
        "database",
        "worker-service",
        "integration",
        "infrastructure",
        "governance",
        "mixed"
      ]
    },
    "technologies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "governanceVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
    },
    "workflowInterfaceVersion": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
    },
    "supportedEvidenceSchemaVersions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^1\\.[01]\\.0$"
      },
      "uniqueItems": true
    },
    "riskClassification": {
      "type": "string",
      "enum": [
        "Low",
        "Moderate",
        "High",
        "Critical"
      ]
    },
    "dataClassification": {
      "type": "string",
      "enum": [
        "Public",
        "Internal",
        "Confidential",
        "Regulated"
      ]
    },
    "owners": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3,
        "pattern": "^(@[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?(?:/[A-Za-z0-9](?:[A-Za-z0-9_.-]*[A-Za-z0-9])?)?|[A-Za-z0-9_.+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,})$",
        "not": {
          "pattern": "^(?:@(?:(?:[Pp][Ll][Aa][Cc][Ee][Hh][Oo][Ll][Dd][Ee][Rr]|[Cc][Hh][Aa][Nn][Gg][Ee][Mm][Ee]|[Rr][Ee][Pp][Ll][Aa][Cc][Ee]-[Mm][Ee]|[Tt][Oo][Dd][Oo])(?:/|$)|[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?/(?:[Pp][Ll][Aa][Cc][Ee][Hh][Oo][Ll][Dd][Ee][Rr]|[Cc][Hh][Aa][Nn][Gg][Ee][Mm][Ee]|[Rr][Ee][Pp][Ll][Aa][Cc][Ee]-[Mm][Ee]|[Tt][Oo][Dd][Oo])$)|(?:[Pp][Ll][Aa][Cc][Ee][Hh][Oo][Ll][Dd][Ee][Rr]|[Cc][Hh][Aa][Nn][Gg][Ee][Mm][Ee]|[Rr][Ee][Pp][Ll][Aa][Cc][Ee]-[Mm][Ee]|[Tt][Oo][Dd][Oo])@)"
        }
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "environments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "type",
          "production"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 2, "maxLength": 80 },
          "type": {
            "type": "string",
            "enum": [
              "development",
              "test",
              "staging",
              "production"
            ]
          },
          "production": { "type": "boolean" },
          "region": { "type": ["string", "null"], "minLength": 1, "maxLength": 80 },
          "zone": { "type": ["string", "null"], "minLength": 1, "maxLength": 80 },
          "cluster": { "type": ["string", "null"], "minLength": 1, "maxLength": 80 },
          "namespace": { "type": ["string", "null"], "minLength": 1, "maxLength": 80 }
        }
      }
    },
    "applicableStandards": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^agents/AGENTS_[A-Za-z]+\\.md$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "requiredWorkflows": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "externalIntegrations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "purpose",
          "dataClassification"
        ],
        "properties": {
          "name": { "type": "string", "minLength": 2 },
          "purpose": { "type": "string", "minLength": 20 },
          "dataClassification": {
            "type": "string",
            "enum": [
              "Public",
              "Internal",
              "Confidential",
              "Regulated"
            ]
          },
          "contractVersion": { "type": ["string", "null"], "minLength": 1, "maxLength": 80 },
          "authenticationMethod": { "type": ["string", "null"], "minLength": 1, "maxLength": 120 }
        }
      }
    },
    "secretsProvider": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "productionApprovalRequired": {
      "type": "boolean"
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completionEvidencePath",
        "testEvidencePath"
      ],
      "properties": {
        "completionEvidencePath": {
          "type": "string",
          "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+\\.json$"
        },
        "testEvidencePath": {
          "type": "string",
          "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+\\.json$"
        },
        "artifactManifestPath": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+\\.json$"
        }
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^GOV-[A-Z0-9-]+$"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "riskClassification": {
            "enum": [
              "High",
              "Critical"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "productionApprovalRequired": {
            "const": true
          }
        }
      }
    }
  ]
}
