{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aiallthethingz.example/engineering-standards/governance-config.schema.json",
  "title": "Governance Configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "manifestPath",
    "evidencePath",
    "requiredDocumentationPaths",
    "applicableAgentStandards",
    "validationCategories",
    "additionalForbiddenPatterns",
    "reviewedAllowlist",
    "controls",
    "exceptions"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": [
        "1.0.0",
        "1.1.0"
      ]
    },
    "manifestPath": {
      "type": "string",
      "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+\\.json$"
    },
    "evidencePath": {
      "type": "string",
      "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+"
    },
    "requiredDocumentationPaths": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+\\.md$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "applicableAgentStandards": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^agents/AGENTS_[A-Za-z]+\\.md$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "validationCategories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Contract",
          "JsonSchemas",
          "MarkdownLinks",
          "DocumentationCompleteness",
          "ForbiddenPatterns",
          "RepositoryHealth",
          "CodexSkills",
          "Evidence",
          "Examples",
          "WorkflowArchitecture"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "schemaSupport": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "supportedCompletionSchemaVersions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^1\\.[01]\\.0$"
          },
          "uniqueItems": true
        },
        "supportedTestEvidenceSchemaVersions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^1\\.[01]\\.0$"
          },
          "uniqueItems": true
        },
        "supportedArtifactRecordSchemaVersions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^1\\.[01]\\.0$"
          },
          "uniqueItems": true
        },
        "minimumSupportedGovernanceVersion": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
        },
        "compatibilityWindow": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 5,
          "maxLength": 200
        }
      }
    },
    "workflowInterfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3,
        "maxLength": 120
      },
      "uniqueItems": true
    },
    "branchProtectionCheckName": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 3,
      "maxLength": 160
    },
    "ownership": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredCodeownerPaths"
      ],
      "properties": {
        "requiredCodeownerPaths": {
          "type": "array",
          "description": "Repository-specific rooted literal CODEOWNERS paths that must exist and have effective ownership.",
          "items": {
            "type": "string",
            "pattern": "^/(?!/)(?!.*[\\*?\\[\\]#!\\\\\\s:])(?:\\.[A-Za-z0-9_-]|[A-Za-z0-9_-])(?:[A-Za-z0-9._-]*[A-Za-z0-9_-])?(?:/(?:\\.[A-Za-z0-9_-]|[A-Za-z0-9_-])(?:[A-Za-z0-9._-]*[A-Za-z0-9_-])?)*/?$",
            "not": {
              "pattern": "(?:^|/)(?:[Pp][Ll][Aa][Cc][Ee][Hh][Oo][Ll][Dd][Ee][Rr]|[Cc][Hh][Aa][Nn][Gg][Ee][Mm][Ee]|[Rr][Ee][Pp][Ll][Aa][Cc][Ee]-[Mm][Ee]|[Tt][Oo][Dd][Oo])(?:/|$)"
            }
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "additionalForbiddenPatterns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "severity",
          "regex"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{2,80}$"
          },
          "description": {
            "type": "string",
            "minLength": 20
          },
          "severity": {
            "type": "string",
            "enum": [
              "warning",
              "error"
            ]
          },
          "regex": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    },
    "reviewedAllowlist": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "patternId",
          "path",
          "owner",
          "reason",
          "expiresOn"
        ],
        "properties": {
          "patternId": {
            "type": "string"
          },
          "path": {
            "type": "string",
            "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+"
          },
          "owner": {
            "type": "string",
            "minLength": 3
          },
          "reason": {
            "type": "string",
            "minLength": 10
          },
          "expiresOn": {
            "type": "string",
            "format": "date"
          }
        }
      }
    },
    "controls": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mandatoryControlsDisabled"
      ],
      "properties": {
        "mandatoryControlsDisabled": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "control",
              "exceptionReference"
            ],
            "properties": {
              "control": {
                "type": "string",
                "minLength": 3
              },
              "exceptionReference": {
                "type": "string",
                "pattern": "^GOV-[A-Z0-9-]+$"
              }
            }
          }
        }
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^GOV-[A-Z0-9-]+$"
      }
    }
  }
}
