{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.aiallthethingz.example/engineering-standards/artifact-record.schema.json",
  "title": "Artifact Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "artifactType",
    "path",
    "mediaType",
    "sizeBytes",
    "sha256",
    "createdAtUtc",
    "producer",
    "retention",
    "sensitivity",
    "relatedTest"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "artifactType": {
      "type": "string",
      "enum": [
        "log",
        "report",
        "test-result",
        "coverage",
        "package",
        "screenshot",
        "evidence",
        "other"
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!.*\\.\\.).+"
    },
    "mediaType": {
      "type": "string",
      "minLength": 1
    },
    "sizeBytes": {
      "type": "integer",
      "minimum": 0
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "createdAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "retention": {
      "type": "string",
      "enum": [
        "ci-run",
        "release",
        "audit",
        "temporary"
      ]
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "Public",
        "Internal",
        "Confidential",
        "Restricted"
      ]
    },
    "relatedTest": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
