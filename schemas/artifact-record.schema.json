{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:aiallthethingz:engineering-standards:schema:artifact-record",
  "title": "Artifact Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "artifactType",
    "path",
    "mediaType",
    "sizeBytes",
    "sha256",
    "createdAtUtc",
    "producer",
    "retention",
    "sensitivity",
    "relatedTest"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": [
        "1.0.0",
        "1.1.0"
      ]
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._:/()#-]*$"
    },
    "artifactType": {
      "type": "string",
      "enum": [
        "log",
        "report",
        "test-result",
        "coverage",
        "package",
        "screenshot",
        "evidence",
        "manifest",
        "other"
      ]
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?!/).+"
    },
    "mediaType": {
      "type": "string",
      "pattern": "^[a-z0-9.+-]+/[a-z0-9.+-]+$"
    },
    "sizeBytes": {
      "type": "integer",
      "minimum": 0
    },
    "hashAlgorithm": {
      "type": "string",
      "enum": [
        "SHA-256"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^[A-Fa-f0-9]{64}$"
    },
    "createdAtUtc": {
      "type": "string",
      "format": "date-time"
    },
    "publishedAtUtc": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160
    },
    "retention": {
      "type": "string",
      "enum": [
        "ci-run",
        "release",
        "audit",
        "temporary"
      ]
    },
    "expiresAtUtc": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "sensitivity": {
      "type": "string",
      "enum": [
        "Public",
        "Internal",
        "Confidential",
        "Regulated"
      ]
    },
    "classification": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "Public",
        "Internal",
        "Confidential",
        "Regulated",
        null
      ]
    },
    "relatedTest": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 3,
      "maxLength": 120
    },
    "sourceCommitSha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "validatedCommitSha": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Fa-f0-9]{40}$"
    },
    "githubRunId": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]+$"
    },
    "githubRunAttempt": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]+$"
    },
    "jobName": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 160
    },
    "finality": {
      "type": "string",
      "enum": [
        "final",
        "partial"
      ]
    },
    "signed": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "attested": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "authorizationBoundary": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 3,
      "maxLength": 160
    },
    "verifiedAtUtc": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "verifiedBy": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 2,
      "maxLength": 160
    },
    "integrityVerification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "Passed",
            "Failed",
            "NotRun",
            "Blocked",
            "NotApplicable"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "retention": {
            "enum": [
              "release",
              "audit"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "sha256": {
            "pattern": "^[A-Fa-f0-9]{64}$"
          },
          "sizeBytes": {
            "minimum": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "finality": {
            "const": "final"
          }
        }
      },
      "then": {
        "required": [
          "integrityVerification"
        ]
      }
    }
  ]
}
